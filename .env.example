# ---------------------------------------------------------------------------
# HealthVision AI — environment configuration
# Copy to `.env` (cp .env.example .env). Defaults work for docker-compose.
# ---------------------------------------------------------------------------

# --- App ---
APP_NAME=HealthVision AI
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Postgres (used by docker-compose to provision the DB) ---
POSTGRES_USER=healthvision
POSTGRES_PASSWORD=healthvision
POSTGRES_DB=healthvision

# --- Database URLs (overridden per-service in docker-compose) ---
DATABASE_URL=postgresql+asyncpg://healthvision:healthvision@localhost:5432/healthvision
SYNC_DATABASE_URL=postgresql+psycopg2://healthvision:healthvision@localhost:5432/healthvision

# --- Message broker (RabbitMQ) ---
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# --- Storage ---
STORAGE_DIR=/data/uploads

# --- Uploads / validation ---
MAX_UPLOAD_SIZE_MB=10

# --- AI ---
# USE_MOCK_INFERENCE=false uses the REAL pretrained chest X-ray model
# (torchxrayvision), bundled in the backend Docker image.
USE_MOCK_INFERENCE=false
MODEL_WEIGHTS_PATH=
CONFIDENCE_UNCERTAIN_THRESHOLD=0.55

# torchxrayvision model + decision thresholds on the pneumonia/opacity score.
XRAY_MODEL_NAME=densenet121-res224-all
XRAY_PNEUMONIA_HIGH=0.50
XRAY_PNEUMONIA_LOW=0.35
